{
  "name": "json-dynamic-viewer",
  "version": "0.2.1",
  "description": "A dynamic, configurable JSON viewer library for React with per-key behavior and formatting",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./style.css": "./dist/style.css"
  },
  "files": [
    "dist"
  ],
  "sideEffects": [
    "./dist/style.css"
  ],
  "author": "Jaime Giraldo",
  "homepage": "https://www.jaime-giraldo.com/json_dynamic_viewer/",
  "repository": {
    "type": "git",
    "url": "https://github.com/sposmen/json_dynamic_viewer.git"
  },
  "bugs": {
    "url": "https://github.com/sposmen/json_dynamic_viewer/issues"
  },
  "keywords": [
    "react",
    "json",
    "viewer",
    "json-viewer",
    "dynamic",
    "tabulator"
  ],
  "license": "MIT",
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^6.0.1",
    "vite": "^8.0.12"
  },
  "dependencies": {
    "tabulator-tables": "^6.3.0"
  }
}
