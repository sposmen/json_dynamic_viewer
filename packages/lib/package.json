{
  "name": "json-dynamic-viewer",
  "version": "0.3.0",
  "description": "A dynamic, configurable JSON viewer library for React with per-key behavior and formatting",
  "type": "module",
  "module": "./dist/index.js",
  "exports": {
    ".": {
      "import": "./dist/index.js"
    },
    "./adapters/tabulator": {
      "import": "./dist/adapters/tabulator.js"
    },
    "./adapters/tabulator/themes/simple": {
      "import": "./dist/adapters/tabulator/themes/simple.js"
    },
    "./adapters/tabulator/themes/midnight": {
      "import": "./dist/adapters/tabulator/themes/midnight.js"
    },
    "./adapters/tabulator/themes/modern": {
      "import": "./dist/adapters/tabulator/themes/modern.js"
    },
    "./adapters/tabulator/themes/site": {
      "import": "./dist/adapters/tabulator/themes/site.js"
    },
    "./adapters/tabulator/themes/site-dark": {
      "import": "./dist/adapters/tabulator/themes/site-dark.js"
    },
    "./adapters/gridjs": {
      "import": "./dist/adapters/gridjs.js"
    },
    "./adapters/gridjs/themes/mermaid": {
      "import": "./dist/adapters/gridjs/themes/mermaid.js"
    },
    "./style.css": "./dist/style.css"
  },
  "files": [
    "dist"
  ],
  "sideEffects": [
    "./dist/style.css"
  ],
  "author": "Jaime Giraldo",
  "homepage": "https://www.jaime-giraldo.com/json_dynamic_viewer/",
  "repository": {
    "type": "git",
    "url": "https://github.com/sposmen/json_dynamic_viewer.git"
  },
  "bugs": {
    "url": "https://github.com/sposmen/json_dynamic_viewer/issues"
  },
  "keywords": [
    "react",
    "json",
    "viewer",
    "json-viewer",
    "dynamic",
    "plugin",
    "adapter"
  ],
  "license": "MIT",
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0",
    "tabulator-tables": ">=6.0.0",
    "gridjs": ">=6.0.0",
    "gridjs-react": ">=6.0.0"
  },
  "peerDependenciesMeta": {
    "tabulator-tables": {
      "optional": true
    },
    "gridjs": {
      "optional": true
    },
    "gridjs-react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^6.0.1",
    "gridjs": "^6.2.0",
    "gridjs-react": "^6.1.1",
    "tabulator-tables": "^6.3.0",
    "vite": "^8.0.12"
  }
}
